#!/bin/sh

# This script validates assignment names and test files, creates .turnip directory structure, extracts tar archives, and prevents duplicate assignments

# Function to validate assignment name
validate_assignment_name() {
    if [ -z "$1" ]; then
        echo "Error: Assignment name cannot be empty."
        exit 1
    fi
    echo "Valid assignment name: $1"
}

# Function to validate test file
validate_test_file() {
    if [ ! -f "$1" ]; then
        echo "Error: Test file $1 does not exist."
        exit 1
    fi
    echo "Test file $1 exists."
}

# Create .turnip directory structure if it does not exist
create_directory_structure() {
    if [ ! -d "$HOME/.turnip" ]; then
        mkdir -p "$HOME/.turnip/assignments"
        mkdir -p "$HOME/.turnip/tests"
        echo ".turnip directory structure created."
    else
        echo ".turnip directory structure already exists."
    fi
}

# Extract tar archives
extract_tar_archives() {
    for archive in "$@"; do
        if [ -f "$archive" ]; then
            tar -xvf "$archive" -C "$HOME/.turnip/assignments"
            echo "Extracted $archive"
        else
            echo "Warning: $archive does not exist."
        fi
    done
}

# Prevent duplicate assignments
prevent_duplicate_assignments() {
    ASSIGNMENT_NAME="$1"
    if [ -d "$HOME/.turnip/assignments/$ASSIGNMENT_NAME" ]; then
        echo "Error: Assignment $ASSIGNMENT_NAME already exists."
        exit 1
    fi
}

# Main script execution
ASSIGNMENT_NAME="$1"
TEST_FILE="$2"

validate_assignment_name "$ASSIGNMENT_NAME"
validate_test_file "$TEST_FILE"
create_directory_structure
prevent_duplicate_assignments "$ASSIGNMENT_NAME"

# Assuming tar files are passed as arguments from the command line
shift 2
extract_tar_archives "$@"
