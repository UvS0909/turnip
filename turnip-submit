#!/bin/bash

# turnip-submit script
# Handles student submissions
# Current Date: 2026-03-19 10:37:44

# Define a function to handle submissions
submit_assignment() {
    local student_name="$1"
    local assignment_path="$2"
    local submit_dir="./submissions/${student_name}"

    # Create submission directory if it doesn't exist
    mkdir -p "$submit_dir"

    # Copy the assignment to the submission directory
    cp "$assignment_path" "$submit_dir/"
    echo "Submission received from $student_name"
}

# Check if the correct number of arguments is given
if [ "$#" -ne 2 ]; then
    echo "Usage: $0 <student_name> <assignment_path>"
    exit 1
fi

# Call the submission function with provided arguments
submit_assignment "$1" "$2"